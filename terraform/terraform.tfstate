    {
      "mode": "managed",
      "type": "aws_ecs_task_definition",
      "name": "migrate",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "arn": "arn:aws:ecs:us-east-1:659775407889:task-definition/rodrigo-falcao-noteflow-migrate:2",
            "arn_without_revision": "arn:aws:ecs:us-east-1:659775407889:task-definition/rodrigo-falcao-noteflow-migrate",
            "container_definitions": "[{\"command\":[\"/bin/sh\",\"-c\",\"set -e\\necho \\\"==\u003e Checking DB connection...\\\"\\npsql -c \\\"SELECT 1\\\" \u003e /dev/null\\necho \\\"==\u003e Creating datadog user...\\\"\\npsql -c \\\"CREATE USER datadog WITH PASSWORD '$$DD_PGPASSWORD'\\\" 2\u003e\u00261 || echo \\\"(user already exists, continuing)\\\"\\npsql -c \\\"GRANT pg_monitor TO datadog\\\"\\npsql -c \\\"CREATE SCHEMA IF NOT EXISTS datadog\\\"\\npsql -c \\\"GRANT USAGE ON SCHEMA datadog TO datadog\\\"\\npsql -c \\\"GRANT CREATE ON SCHEMA datadog TO datadog\\\"\\npsql -c \\\"CREATE EXTENSION IF NOT EXISTS pg_stat_statements\\\"\\npsql -c \\\"CREATE OR REPLACE FUNCTION datadog.explain_statement(l_query TEXT, OUT explain JSON) RETURNS SETOF JSON AS \\\\$plpgsql\\\\$DECLARE curs REFCURSOR; plan JSON; BEGIN OPEN curs FOR EXECUTE pg_catalog.concat('EXPLAIN (FORMAT JSON) ', l_query); FETCH curs INTO plan; CLOSE curs; RETURN QUERY SELECT plan; END;\\\\$plpgsql\\\\$ LANGUAGE plpgsql RETURNS NULL ON NULL INPUT SECURITY DEFINER\\\"\\necho \\\"==\u003e DBM setup complete!\\\"\\n\"],\"environment\":[{\"name\":\"PGDATABASE\",\"value\":\"noteflow\"},{\"name\":\"PGHOST\",\"value\":\"rodrigo-falcao-noteflow-postgres.cgfiqqiks90e.us-east-1.rds.amazonaws.com\"},{\"name\":\"PGPORT\",\"value\":\"5432\"},{\"name\":\"PGUSER\",\"value\":\"noteflow\"}],\"essential\":true,\"image\":\"postgres:16-alpine\",\"logConfiguration\":{\"logDriver\":\"awslogs\",\"options\":{\"awslogs-group\":\"/ecs/rodrigo-falcao-noteflow/migrate\",\"awslogs-region\":\"us-east-1\",\"awslogs-stream-prefix\":\"migrate\"}},\"mountPoints\":[],\"name\":\"migrate\",\"portMappings\":[],\"secrets\":[{\"name\":\"DD_PGPASSWORD\",\"valueFrom\":\"arn:aws:ssm:us-east-1:659775407889:parameter/noteflow/datadog_password\"},{\"name\":\"PGPASSWORD\",\"valueFrom\":\"arn:aws:ssm:us-east-1:659775407889:parameter/noteflow/db_password\"}],\"systemControls\":[],\"volumesFrom\":[]}]",
            "cpu": "256",
            "enable_fault_injection": false,
